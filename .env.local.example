# Configuration client Firebase (Console Firebase > Paramètres du projet > Vos applications > Web)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK (Console Firebase > Paramètres du projet > Comptes de service > Générer une nouvelle clé privée)
# Copiez client_email et private_key du fichier JSON téléchargé.
# Gardez les guillemets et les \n dans FIREBASE_ADMIN_PRIVATE_KEY tels quels.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=""
